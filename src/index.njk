---
title: Home
layout: base.njk
---
<section class="hero">
  <div class="hero-grid">
    <div class="hero-text h-card">
      <h1 class="hero-headline">
        Hi, my name is <span class="p-name">Pepijn Schoen</span>.
      </h1>
      <div class="hero-accent"></div>
      <p class="hero-description p-note">
        I'm an engineering leader at Enpal. I really like cats, they are soft and fluffy. After working for a year at a coffee store, I am now a certified snob. My musical skills are unfortunately absent, but I compensate this with enthusiasm. I write poetry, sometimes, and ride my bicycle.
      </p>
      <a class="u-url" href="{{ site.url }}" hidden>{{ site.url }}</a>
    </div>
    <div class="hero-portrait">
      <div class="portrait-frame">
        <img src="/img/portrait.png" alt="Portrait of Pepijn Schoen" />
      </div>
    </div>
  </div>
</section>

{% set posts = collections.writing %}
{% if posts.length > 0 %}
<section class="articles-section">
  <div class="articles-inner">
    <ul class="articles-list">
      {% for post in posts %}
      {% if loop.index <= 5 %}
      <li class="article-item">
        <h3 class="article-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        {% if post.data.excerpt %}
        <p class="article-excerpt">{{ post.data.excerpt }}</p>
        {% endif %}
      </li>
      {% endif %}
      {% endfor %}
    </ul>
  </div>
</section>
{% endif %}
