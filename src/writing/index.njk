---
title: Writing
layout: base.njk
---
<div class="writing-index">
  {% set posts = collections.writing %}
  {% if posts.length > 0 %}
  <ul class="writing-list">
    {% for post in posts %}
    <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
    {% endfor %}
  </ul>
  {% endif %}
</div>
